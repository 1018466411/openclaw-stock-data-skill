{
  "name": "stock_data_api",
  "version": "1.0.0",
  "description": "股票数据 API Skill - 提供完整的 A 股市场数据访问功能，包括行情、财务、实时数据等。使用前请先访问 https://data.diemeng.chat/ 注册并获取 API Key。",
  "author": "Stock API Team",
  "license": "MIT",
  "homepage": "https://data.diemeng.chat/",
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [
    "stock",
    "股票",
    "finance",
    "financial data",
    "market data",
    "A股",
    "行情数据",
    "财务数据"
  ],
  "tools": [
    {
      "name": "get_stock_list",
      "description": "获取股票列表，支持按股票代码筛选",
      "parameters": {
        "type": "object",
        "properties": {
          "stock_code": {
            "type": "string",
            "description": "股票代码（可选），例如 '600000.SH'"
          },
          "page": {
            "type": "integer",
            "description": "页码，从0开始，默认0"
          },
          "page_size": {
            "type": "integer",
            "description": "每页数量，默认20000"
          }
        }
      }
    },
    {
      "name": "get_daily_data",
      "description": "获取日K线数据，支持单只或多只股票",
      "parameters": {
        "type": "object",
        "properties": {
          "stock_code": {
            "type": ["string", "array"],
            "description": "股票代码，支持单个字符串或数组，例如 '600000.SH' 或 ['600000.SH', '000001.SZ']"
          },
          "start_time": {
            "type": "string",
            "description": "开始日期，格式 YYYY-MM-DD"
          },
          "end_time": {
            "type": "string",
            "description": "结束日期，格式 YYYY-MM-DD"
          },
          "page": {
            "type": "integer",
            "description": "页码，从0开始，默认0"
          },
          "page_size": {
            "type": "integer",
            "description": "每页数量，默认10000"
          }
        },
        "required": ["start_time", "end_time"]
      }
    },
    {
      "name": "get_history_data",
      "description": "获取历史分时数据，支持1分钟、5分钟、15分钟、30分钟、60分钟级别",
      "parameters": {
        "type": "object",
        "properties": {
          "stock_code": {
            "type": ["string", "array"],
            "description": "股票代码，支持单个字符串或数组"
          },
          "level": {
            "type": "string",
            "enum": ["1min", "5min", "15min", "30min", "60min"],
            "description": "时间级别，默认5min"
          },
          "start_time": {
            "type": "string",
            "description": "开始时间，格式 YYYY-MM-DD 或 YYYY-MM-DD HH:MM:SS"
          },
          "end_time": {
            "type": "string",
            "description": "结束时间，格式 YYYY-MM-DD 或 YYYY-MM-DD HH:MM:SS"
          },
          "page": {
            "type": "integer",
            "description": "页码，从0开始，默认0"
          },
          "page_size": {
            "type": "integer",
            "description": "每页数量，默认10000"
          }
        },
        "required": ["start_time", "end_time"]
      }
    },
    {
      "name": "get_finance_data",
      "description": "获取每日财务数据，包括PE、PB、PS、市值等指标",
      "parameters": {
        "type": "object",
        "properties": {
          "stock_code": {
            "type": ["string", "array"],
            "description": "股票代码，支持单个字符串或数组"
          },
          "start_time": {
            "type": "string",
            "description": "开始日期，格式 YYYY-MM-DD"
          },
          "end_time": {
            "type": "string",
            "description": "结束日期，格式 YYYY-MM-DD"
          },
          "page": {
            "type": "integer",
            "description": "页码，从0开始，默认0"
          },
          "page_size": {
            "type": "integer",
            "description": "每页数量，默认10000"
          }
        },
        "required": ["start_time", "end_time"]
      }
    },
    {
      "name": "get_stock_valuation",
      "description": "获取股票估值列表，支持按PE、百分位等排序",
      "parameters": {
        "type": "object",
        "properties": {
          "sort_by": {
            "type": "string",
            "enum": ["pe_ttm", "pe_percentile", "dividend_yield_ttm", "industry_pe_rank"],
            "description": "排序字段，默认pe_ttm"
          },
          "sort_order": {
            "type": "string",
            "enum": ["asc", "desc"],
            "description": "排序方向，默认asc"
          },
          "industry": {
            "type": "string",
            "description": "行业筛选（可选）"
          },
          "limit": {
            "type": "integer",
            "description": "返回数量限制，默认100"
          },
          "offset": {
            "type": "integer",
            "description": "偏移量，默认0"
          }
        }
      }
    },
    {
      "name": "get_call_auction",
      "description": "获取集合竞价数据",
      "parameters": {
        "type": "object",
        "properties": {
          "stock_code": {
            "type": ["string", "array"],
            "description": "股票代码，支持单个字符串或数组"
          },
          "start_time": {
            "type": "string",
            "description": "开始时间，格式 YYYY-MM-DD 或 YYYY-MM-DD HH:MM:SS"
          },
          "end_time": {
            "type": "string",
            "description": "结束时间，格式 YYYY-MM-DD 或 YYYY-MM-DD HH:MM:SS"
          },
          "page": {
            "type": "integer",
            "description": "页码，从0开始，默认0"
          },
          "page_size": {
            "type": "integer",
            "description": "每页数量，默认10000"
          }
        },
        "required": ["start_time", "end_time"]
      }
    },
    {
      "name": "get_closing_snapshot",
      "description": "获取收盘快照数据",
      "parameters": {
        "type": "object",
        "properties": {
          "stock_code": {
            "type": ["string", "array"],
            "description": "股票代码，支持单个字符串或数组"
          },
          "start_time": {
            "type": "string",
            "description": "开始时间，格式 YYYY-MM-DD 或 YYYY-MM-DD HH:MM:SS"
          },
          "end_time": {
            "type": "string",
            "description": "结束时间，格式 YYYY-MM-DD 或 YYYY-MM-DD HH:MM:SS"
          },
          "page": {
            "type": "integer",
            "description": "页码，从0开始，默认0"
          },
          "page_size": {
            "type": "integer",
            "description": "每页数量，默认10000"
          }
        },
        "required": ["start_time", "end_time"]
      }
    },
    {
      "name": "get_trade_calendar",
      "description": "获取交易日历",
      "parameters": {
        "type": "object",
        "properties": {
          "start_time": {
            "type": "string",
            "description": "开始日期，格式 YYYY-MM-DD"
          },
          "end_time": {
            "type": "string",
            "description": "结束日期，格式 YYYY-MM-DD"
          }
        },
        "required": ["start_time", "end_time"]
      }
    },
    {
      "name": "search_stock_by_name",
      "description": "根据股票名称搜索股票（支持模糊匹配）",
      "parameters": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "股票名称，支持模糊匹配"
          }
        },
        "required": ["name"]
      }
    },
    {
      "name": "get_stock_info",
      "description": "获取单个股票的详细信息",
      "parameters": {
        "type": "object",
        "properties": {
          "stock_code": {
            "type": "string",
            "description": "股票代码，例如 '600000.SH'"
          }
        },
        "required": ["stock_code"]
      }
    }
  ],
  "requirements": [
    "requests>=2.31.0"
  ],
  "configuration": {
    "api_key": {
      "type": "string",
      "description": "在 https://data.diemeng.chat/ 注册登录后，在个人中心获取 API Key，并填在此处后保存。",
      "required": true,
      "env": "STOCK_API_KEY"
    },
    "base_url": {
      "type": "string",
      "description": "API 基础地址",
      "default": "https://data.diemeng.chat/api"
    }
  }
}
